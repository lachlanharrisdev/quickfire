---
import Layout from "@/components/Layout.astro";
import { Navbar } from "@/components/Navbar";

export function getStaticPaths() {
    return [
        { params: { slug: "flow-rate" }, props: { name: "Flow Rate" } },
        { params: { slug: "fire-danger" }, props: { name: "Fire Danger" } },
        { params: { slug: "fire-speed" }, props: { name: "Fire Speed" } },
        { params: { slug: "pressure" }, props: { name: "Pressure Loss" } },
        { params: { slug: "eta" }, props: { name: "ETA" } },
        { params: { slug: "distance" }, props: { name: "Distance" } },
    ];
}

const { slug } = Astro.params;
const { name } = Astro.props;

const isEta = slug === "eta";
---

<Layout title={`${name} | Quickfire`}>
    <section
        class="p-3 pb-0 flex-1 flex flex-col gap-2 w-full max-w-xl mx-auto min-h-0"
    >
        <div class="flex items-center gap-3 mb-2">
            <a
                href="/calculators"
                class="flex items-center justify-center w-12 h-12 bg-secondary rounded-sm active:bg-primary/20 transition-colors"
                aria-label="Back to calculators"
            >
                <svg
                    class="w-6 h-6 text-primary"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                >
                    <path d="m15 18-6-6 6-6"></path>
                </svg>
            </a>
            <h1
                class="font-tactical-bold text-xl sm:text-2xl text-primary uppercase tracking-wider"
            >
                {name}
            </h1>
        </div>

        {
            isEta ? (
                <div class="flex-1 bg-card border border-border rounded-sm p-4 sm:p-6 flex flex-col gap-4">
                    <p class="text-sm text-muted-foreground">
                        Enter distance and speed to calculate estimated travel
                        time.
                    </p>

                    <form
                        id="eta-form"
                        class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4"
                    >
                        <label class="flex flex-col gap-1.5">
                            <span class="font-tactical text-xs uppercase tracking-wider text-muted-foreground">
                                Distance (km)
                            </span>
                            <input
                                id="distance"
                                type="number"
                                min="0"
                                step="0.1"
                                placeholder="e.g. 42"
                                class="h-11 px-3 bg-secondary border border-border rounded-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/40"
                            />
                        </label>

                        <label class="flex flex-col gap-1.5">
                            <span class="font-tactical text-xs uppercase tracking-wider text-muted-foreground">
                                Speed (km/h)
                            </span>
                            <input
                                id="speed"
                                type="number"
                                min="0"
                                step="0.1"
                                placeholder="e.g. 60"
                                class="h-11 px-3 bg-secondary border border-border rounded-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/40"
                            />
                        </label>
                    </form>

                    <div class="card-tactical-warning p-4">
                        <p class="data-label text-xs mb-1">Estimated Time</p>
                        <p
                            id="eta-output"
                            class="font-tactical-bold text-3xl text-primary tracking-wide"
                        >
                            --h --m
                        </p>
                    </div>
                </div>
            ) : (
                <div class="flex-1 flex flex-col items-center justify-center gap-4 bg-card border border-border rounded-sm p-6">
                    <div class="w-16 h-16 rounded-full bg-secondary flex items-center justify-center">
                        <svg
                            class="w-8 h-8 text-muted-foreground"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M12 6v6l4 2" />
                            <circle cx="12" cy="12" r="9" />
                        </svg>
                    </div>
                    <div class="text-center">
                        <p class="font-tactical text-lg text-foreground uppercase tracking-wider mb-2">
                            Not Implemented
                        </p>
                        <p class="text-sm text-muted-foreground max-w-xs">
                            The {name} calculator hasn't been implemented yet.
                        </p>
                    </div>
                </div>
            )
        }

        <Navbar active="calculators" />
    </section>
</Layout>

<script>
    const form = document.getElementById("eta-form");
    const output = document.getElementById("eta-output");
    const distanceInput = document.getElementById("distance");
    const speedInput = document.getElementById("speed");

    function updateEta() {
        if (!output || !distanceInput || !speedInput) return;

        const distance = Number((distanceInput as HTMLInputElement).value);
        const speed = Number((speedInput as HTMLInputElement).value);

        if (!distance || !speed || distance <= 0 || speed <= 0) {
            output.textContent = "--h --m";
            return;
        }

        const totalMinutes = Math.round((distance / speed) * 60);
        const hours = Math.floor(totalMinutes / 60);
        const minutes = totalMinutes % 60;

        output.textContent = `${hours}h ${minutes}m`;
    }

    form?.addEventListener("input", updateEta);
</script>
