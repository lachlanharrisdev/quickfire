---
import { Layout } from "@globals"
import { Navbar } from "@/components/Navbar"
---

{/* TODO: replace with proper icons */}

<Layout title="Calculators | Quickfire">
	<section class="p-3 pb-0 flex-1 flex flex-col gap-2 w-full max-w-xl mx-auto min-h-0">
		<h1 class="text-xl sm:text-2xl font-bold text-primary">Calculators</h1>

		<div class="flex-1 grid grid-cols-2 gap-2 sm:gap-3 overflow-y-auto pb-2 min-h-0">
			<a href="/calc/flow-rate" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/>
					<path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">Flow Rate</span>
			</a>

			<a href="/calc/fire-danger" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">Fire Danger</span>
			</a>

			<a href="/calc/fire-speed" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"/>
					<path d="M9.6 4.6A2 2 0 1 1 11 8H2"/>
					<path d="M12.6 19.4A2 2 0 1 0 14 16H2"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">Fire Speed</span>
			</a>

			<a href="/calc/pressure" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="m12 14 4-4"/>
					<path d="M3.34 19a10 10 0 1 1 17.32 0"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">Pressure Loss</span>
			</a>

			<a href="/calc/eta" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="10"/>
					<polyline points="12 6 12 12 16 14"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">ETA</span>
			</a>

			<a href="/calc/distance" class="flex flex-col items-center justify-center gap-1 sm:gap-2 p-4 sm:p-6 bg-card border border-border rounded-xl sm:rounded-2xl active:scale-95 transition-transform">
				<svg class="w-8 h-8 sm:w-10 sm:h-10 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21.3 15.3a2.4 2.4 0 0 1 0 3.4l-2.6 2.6a2.4 2.4 0 0 1-3.4 0L2.7 8.7a2.41 2.41 0 0 1 0-3.4l2.6-2.6a2.41 2.41 0 0 1 3.4 0Z"/>
					<path d="m14.5 12.5 2-2"/>
					<path d="m11.5 9.5 2-2"/>
					<path d="m8.5 6.5 2-2"/>
					<path d="m17.5 15.5 2-2"/>
				</svg>
				<span class="text-xs sm:text-sm font-semibold text-center">Distance</span>
			</a>
		</div>

		<Navbar client:load active="calculators" />
	</section>
</Layout>
