---
import { Layout } from "@globals"
import { Navbar } from "@/components/Navbar"
---

<Layout title="Settings | Quickfire">
	<section class="p-3 pb-0 flex-1 flex flex-col gap-2 w-full max-w-xl mx-auto min-h-0">
		<h1 class="text-xl sm:text-2xl font-bold text-primary">Settings</h1>

		<div class="flex-1 flex flex-col gap-3 sm:gap-4 overflow-y-auto pb-2 min-h-0">
			<div class="bg-card border border-border rounded-xl sm:rounded-2xl p-3 sm:p-4">
				<h2 class="text-base sm:text-lg font-semibold mb-3 sm:mb-4">Theme</h2>
				<div class="flex gap-2 sm:gap-3">
					<button
						id="theme-dark"
						class="flex-1 flex flex-col items-center justify-center gap-1 sm:gap-2 p-3 sm:p-4 bg-secondary rounded-lg sm:rounded-xl active:scale-95 transition-transform border-2 border-primary"
					>
						<svg class="w-6 h-6 sm:w-8 sm:h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
						</svg>
						<span class="text-xs sm:text-sm font-medium">Dark</span>
					</button>
					<button
						id="theme-light"
						class="flex-1 flex flex-col items-center justify-center gap-1 sm:gap-2 p-3 sm:p-4 bg-secondary rounded-lg sm:rounded-xl active:scale-95 transition-transform border-2 border-transparent"
					>
						<svg class="w-6 h-6 sm:w-8 sm:h-8" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<circle cx="12" cy="12" r="4"/>
							<path d="M12 2v2"/>
							<path d="M12 20v2"/>
							<path d="m4.93 4.93 1.41 1.41"/>
							<path d="m17.66 17.66 1.41 1.41"/>
							<path d="M2 12h2"/>
							<path d="M20 12h2"/>
							<path d="m6.34 17.66-1.41 1.41"/>
							<path d="m19.07 4.93-1.41 1.41"/>
						</svg>
						<span class="text-xs sm:text-sm font-medium">Light</span>
					</button>
				</div>
			</div>

			<div class="bg-card border border-border rounded-xl sm:rounded-2xl p-3 sm:p-4">
				<h2 class="text-base sm:text-lg font-semibold mb-3 sm:mb-4">Accessibility</h2>
				<div class="flex flex-col gap-2 sm:gap-3">

					<label class="flex items-center justify-between p-3 sm:p-4 bg-secondary rounded-lg sm:rounded-xl cursor-pointer">
						<div class="flex items-center gap-2 sm:gap-3">
							<svg class="w-5 h-5 sm:w-6 sm:h-6 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="m2 8 2 2-2 2 2 2-2 2"/>
								<path d="m22 8-2 2 2 2-2 2 2 2"/>
								<rect x="8" y="5" width="8" height="14" rx="1"/>
							</svg>
							<span class="text-sm sm:text-base font-medium">Haptic Feedback</span>
						</div>
						<input type="checkbox" id="haptic" class="w-5 h-5 sm:w-6 sm:h-6 accent-primary" />
					</label>
				</div>
			</div>

			<div class="bg-card border border-border rounded-xl sm:rounded-2xl p-3 sm:p-4">
				<h2 class="text-base sm:text-lg font-semibold mb-1 sm:mb-2">About</h2>
				<p class="text-xs sm:text-sm text-muted-foreground">Quickfire v0.0.0-dev.1</p>
				<p class="text-xs sm:text-sm text-muted-foreground">A rapid-access information panel engineered for firefighters, by firefighters</p>
			</div>
		</div>

		<Navbar client:load active="settings" />
	</section>
</Layout>

<script>
	// Theme controls
	const darkBtn = document.getElementById("theme-dark")
	const lightBtn = document.getElementById("theme-light")

	function setTheme(theme: "dark" | "light") {
		document.documentElement.classList.toggle("light", theme === "light")
		localStorage.setItem("theme", theme)
		darkBtn?.classList.toggle("border-primary", theme === "dark")
		darkBtn?.classList.toggle("border-transparent", theme !== "dark")
		lightBtn?.classList.toggle("border-primary", theme === "light")
		lightBtn?.classList.toggle("border-transparent", theme !== "light")
	}

	const savedTheme = localStorage.getItem("theme") as "dark" | "light" | null
	if (savedTheme) setTheme(savedTheme)

	darkBtn?.addEventListener("click", () => setTheme("dark"))
	lightBtn?.addEventListener("click", () => setTheme("light"))

	// Haptic feedback control
	const hapticCheckbox = document.getElementById("haptic") as HTMLInputElement | null

	function isHapticEnabled(): boolean {
		const stored = localStorage.getItem("haptic-enabled")
		return stored === null ? true : stored === "true"
	}

	function setHapticEnabled(enabled: boolean) {
		localStorage.setItem("haptic-enabled", String(enabled))
	}

	if (hapticCheckbox) {
		hapticCheckbox.checked = isHapticEnabled()
		hapticCheckbox.addEventListener("change", () => {
			setHapticEnabled(hapticCheckbox.checked)
		})
	}
</script>
